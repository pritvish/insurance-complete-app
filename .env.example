# ─────────────────────────────────────────────────────────────────────────────
# Enterprise Insurance Platform — Environment Variables
#
# Copy this file to .env and fill in real values for local development.
# .env is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (all services share these credentials in local dev) ──────────────
DB_USERNAME=eip_user
DB_PASSWORD=eip_pass

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_JWK_URI=http://localhost:8080/realms/insurance/protocol/openid-connect/certs

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Payment — Stripe ──────────────────────────────────────────────────────────
# Get test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_API_KEY=sk_test_REPLACE_ME

# ── Notifications — SendGrid ──────────────────────────────────────────────────
# Get API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.REPLACE_ME

# ── Notifications — Twilio ────────────────────────────────────────────────────
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=AC_REPLACE_ME
TWILIO_AUTH_TOKEN=REPLACE_ME

# ── Documents — GCS ───────────────────────────────────────────────────────────
# Local dev: leave empty to skip GCS (document service will log warnings)
GCS_BUCKET_NAME=eip-documents-local
# Path to GCP service account JSON (for local dev only, never commit the file)
GOOGLE_APPLICATION_CREDENTIALS=

# ── Keycloak admin (docker-compose only) ──────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
