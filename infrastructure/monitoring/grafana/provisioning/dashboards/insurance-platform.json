{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Platform Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",   "value": null },
            { "color": "yellow","value": 0.95 },
            { "color": "green", "value": 0.99 }
          ]},
          "unit": "percentunit",
          "min": 0, "max": 1
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "avg(up{job=~\"customer-service|policy-service|claims-service|payment-service\"})",
        "legendFormat": "Tier-0 Availability"
      }],
      "title": "Tier-0 Availability",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean","max"], "displayMode": "table", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\".+-service|workflow-orchestrator\"}[2m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ],
      "title": "HTTP Request Rate by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "min": 0, "max": 0.1 }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\".+-service|workflow-orchestrator\",status=~\"5..\"}[2m])) by (job) / sum(rate(http_server_requests_seconds_count{job=~\".+-service|workflow-orchestrator\"}[2m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ],
      "title": "HTTP Error Rate (5xx) by Service",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "title": "Latency (p99)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=~\".+-service|workflow-orchestrator\"}[5m])) by (job, le))",
          "legendFormat": "p99 {{job}}"
        }
      ],
      "title": "HTTP p99 Latency by Service",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "Database Connection Pools",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "min": 0 }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 5,
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=~\".+-service|workflow-orchestrator\"}",
          "legendFormat": "Active — {{job}}"
        }
      ],
      "title": "HikariCP Active Connections",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "min": 0 }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 6,
      "targets": [
        {
          "expr": "hikaricp_connections_pending{job=~\".+-service|workflow-orchestrator\"}",
          "legendFormat": "Pending — {{job}}"
        }
      ],
      "title": "HikariCP Pending Connections (pool exhaustion risk)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "Kafka Consumer Lag",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "min": 0 }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "id": 7,
      "targets": [
        {
          "expr": "sum(kafka_consumer_fetch_manager_records_lag{job=~\".+-service|workflow-orchestrator\"}) by (job, topic)",
          "legendFormat": "{{job}} / {{topic}}"
        }
      ],
      "title": "Kafka Consumer Records Lag",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 104,
      "title": "JVM",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes", "min": 0 }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 8,
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\", job=~\".+-service|workflow-orchestrator\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "title": "JVM Heap Used",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "min": 0 }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 9,
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=~\".+-service|workflow-orchestrator\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "title": "JVM Live Threads",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["insurance", "eip", "platform"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Insurance Platform — Overview",
  "uid": "eip-platform-overview",
  "version": 1
}
